{
  "rewrites": [
    { "source": "/sw.js", "destination": "/sw.js" }
  ],
  "headers": {
    "/index.html": { "Cache-Control": "public, max-age=3600" },
    "/manifest.json": { "Cache-Control": "public, max-age=3600" },
    "/sw.js": { "Cache-Control": "public, max-age=0" }
  },
  "trailingSlash": false
}
